# =============================================================================
# urushi-chronicle 環境変数
# =============================================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env

# --- Server ---
PORT=8080

# --- Store Type ---
# ストア実装の選択: "postgres" (PostgreSQL+TimescaleDB) | "memory" (インメモリ)
# 未設定の場合: DATABASE_URLが設定されていればpostgres、なければmemory
# 自動判定に任せる場合はコメントアウトのまま使用してください
# STORE_TYPE=postgres

# --- Database (PostgreSQL + TimescaleDB) ---
# docker compose up でTimescaleDB起動後に使用
POSTGRES_USER=urushi
POSTGRES_PASSWORD=urushi
POSTGRES_DB=urushi_chronicle
DATABASE_URL=postgres://urushi:urushi@localhost:5432/urushi_chronicle?sslmode=disable

# --- MQTT Broker ---
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_TOPIC=urushi-buro/sensors/#
MQTT_CLIENT_ID=urushi-chronicle

# --- CORS ---
# カンマ区切りで許可するオリジンを指定。
# 空文字の場合、CORSヘッダーは付与されない（リバースプロキシ後ろ前提）。
# 参照: docs/adr/002-cors-empty-origin-design.md
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Alert Webhook ---
# 環境アラート通知先のWebhook URL。空文字の場合は通知しない（no-op）。
ALERT_WEBHOOK_URL=

# --- GCP Cloud Storage ---
GCS_BUCKET=urushi-chronicle-dev
